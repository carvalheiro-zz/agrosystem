<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://java.sun.com/xml/ns/javaee" xmlns:web="http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
	xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd" id="WebApp_ID" version="2.5">

	<display-name>Manager</display-name>
	<!-- Welcome Page -->
	<welcome-file-list>
		<welcome-file>/index.html</welcome-file>
	</welcome-file-list>

	<servlet>
		<servlet-name>action</servlet-name>
		<servlet-class>org.apache.struts.action.ActionServlet</servlet-class>
		<init-param>
			<param-name>config</param-name>
			<param-value>/WEB-INF/manager/struts-config-manager.xml,/WEB-INF/struts-config.xml</param-value>
		</init-param>
		<load-on-startup>1</load-on-startup>
	</servlet>

	<servlet-mapping>
		<servlet-name>action</servlet-name>
		<url-pattern>*.src</url-pattern>
	</servlet-mapping>

	<filter>
		<filter-name>filtrarAcesso</filter-name>
		<filter-class>br.com.srcsoftware.modular.manager.filter.FiltroSeguranca</filter-class>
	</filter>
	<filter-mapping>
		<filter-name>filtrarAcesso</filter-name>
		<url-pattern>/restrito/*</url-pattern>
	</filter-mapping>

	<session-config>
		<session-timeout>30</session-timeout>
	</session-config>

	<error-page>
		<error-code>500</error-code>
		<location>/paginas/errors/erro_500.jsp</location>
	</error-page>
	
	<error-page>
		<error-code>404</error-code>
		<location>/paginas/errors/erro_404.jsp</location>
	</error-page>
	
	<filter>  
       <filter-name>UrlRewriteFilter</filter-name>  
       <filter-class>  
              org.tuckey.web.filters.urlrewrite.UrlRewriteFilter  
       </filter-class>  
 
       <init-param>  
              <param-name>logLevel</param-name>    
              <param-value>DEBUG</param-value>    
       </init-param>  
  </filter>  
 
  <filter-mapping>    
       <filter-name>UrlRewriteFilter</filter-name>  
       <url-pattern>/*</url-pattern>    
  </filter-mapping>

</web-app>
